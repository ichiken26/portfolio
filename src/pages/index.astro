---
import ProductCard from "../components/ProductCard.vue";
import TechStackCard from "../components/TechStackCard.tsx";
import { getCollection } from "astro:content";
import { techStacks } from "../data/portfolio";
import Layout from "../layouts/Layout.astro";

const products = (await getCollection("products")).sort((a, b) => a.data.order - b.data.order);
---

<Layout title="KOKAGE Portfolio | Web / App / Pixel Art">
	<main>
		<section class="hero">
			<div class="hero-copy">
				<p class="eyebrow">Web Developer / Creative Builder</p>
				<h1 class="page-title">Web とアプリを、軽く速く扱いやすく作る。</h1>
				<p class="lead">
					Vue/Nuxt、React、FastAPI、Django、Cloudflare、Electron を使い、Web
					からデスクトップまで制作します。Unity と C# は学習中で、Aseprite
					によるドット絵素材も制作できます。
				</p>
				<div class="button-row">
					<a class="button" href="/products/">制作物を見る</a>
					<a class="button secondary" href="/tech-stack/">技術スタック</a>
				</div>
			</div>
			<div class="hero-art" aria-hidden="true">
				<img class="hero-character" src="/sourdMan.svg" alt="" />
			</div>
		</section>

		<section class="home-section">
			<div class="section-heading">
				<p class="eyebrow">Featured Stack</p>
				<h2 class="section-title">扱える技術</h2>
				<a href="/tech-stack/">すべて見る</a>
			</div>
			<div class="card-grid">
				{techStacks.slice(0, 4).map((tech) => <TechStackCard tech={tech} />)}
			</div>
		</section>

		<section class="home-section">
			<div class="section-heading">
				<p class="eyebrow">Products</p>
				<h2 class="section-title">制作物とプロダクト</h2>
				<a href="/products/">一覧へ</a>
			</div>
			<div class="card-grid">
				{products.slice(0, 3).map((product) => <ProductCard product={product} />)}
			</div>
		</section>
	</main>
	<script>
		const hero = document.querySelector<HTMLElement>(".hero");
		const heroCopy = document.querySelector<HTMLElement>(".hero-copy");

		if (hero && heroCopy) {
			const syncHeroArtWidth = () => {
				hero.style.setProperty("--hero-copy-width", `${heroCopy.offsetWidth}px`);
			};

			syncHeroArtWidth();
			new ResizeObserver(syncHeroArtWidth).observe(heroCopy);
			window.addEventListener("load", syncHeroArtWidth);
		}
	</script>
</Layout>

<style>
	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.95fr);
		gap: clamp(28px, 6vw, 72px);
		align-items: center;
		min-height: calc(100vh - 172px);
		padding-bottom: 30px;
	}

	.hero-copy {
		position: relative;
		z-index: 1;
	}

	.hero-art {
		display: grid;
		place-items: center;
		min-height: 420px;
	}

	.hero-character {
		width: min(100%, var(--hero-copy-width, 430px));
		height: auto;
		display: block;
		object-fit: contain;
		image-rendering: pixelated;
	}

	.home-section {
		padding: 56px 0 0;
	}

	.section-heading {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 20px;
		margin-bottom: 22px;
	}

	.section-heading a {
		color: var(--accent-strong);
		font-weight: 800;
		text-decoration: none;
	}

	@media (max-width: 860px) {
		.hero {
			grid-template-columns: 1fr;
			min-height: auto;
		}

		.hero-art {
			min-height: 310px;
		}

		.hero-character {
			width: min(82vw, var(--hero-copy-width, 360px));
		}
	}

	@media (max-width: 560px) {
		.section-heading {
			align-items: flex-start;
			flex-direction: column;
		}
	}
</style>
